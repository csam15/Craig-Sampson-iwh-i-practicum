doctype html
html 
head
     title= `${title}`
     meta(name="viewport" content="width=device-width, initial-scale=1")
     link(rel="stylesheet", href="css\style.css")
     style.
        a{
            font-size: 20px;
        }
        table {
            width: 50%;
            border-collapse: collapse;
            margin: 20px 0;
        }
        th, td {
            border: 1px solid black;
            padding: 8px;
            text-align: left;
        }
        th {
            background-color:rgb(196, 86, 86);
        }

body  
     h1  Custom Object Table
     a(href='/update-cobj') Add/Update this table 
     table  
         thead  
             tr  
                 th  Name   
                 th  Brand   
                 th  Color  
             tr  
         thead  
         tbody
            each item in data
                tr
                    td= item.properties.name || 'N/A'
                    td= item.properties.brand || 'N/A'
                    td= item.properties.color || 'N/A'