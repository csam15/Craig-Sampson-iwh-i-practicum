body  
     h1  Custom Object Table
     table  
         thead  
             tr  
                 th  Name   
                 th  Brand   
                 th  Color    
             tr  
         thead  
         //tbody (id="data-table")  
     table  

     script.  
             //Fetch data using Axios and populate the table
             axios.get("http:    localhost:3000  data")
             .then(response =   {
                const data = response.data;
                const tableBody = document.getElementById("data-table");

                data.forEach(user =   {
                    const row = ` tr  
                                     td  ${user.name}   td  
                                     td  ${user.brand}   td  
                                     td  ${user.color}   td  
                                  tr  `;
                    tableBody.innerHTML += row;
                });
            })
            .catch(error =   console.error("Error fetching data:", error));
     script  
